# Copy to .env.local — Supabase → Project Settings → API Keys

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use either the legacy anon JWT (eyJ...) or the publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (transactional email — server only)
RESEND_API_KEY=
RESEND_DEFAULT_FROM=Pokellection <noreply@yourdomain.com>
# Optional; falls back to site_settings.contact_email then hello@pokellection.com
MANAGER_NOTIFICATION_EMAIL=
